{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "name": "Minecraft Client (:fabric)",
      "request": "launch",
      "command": "./gradlew :fabric:runClient",
      "cwd": "${workspaceFolder}",
      "env": {
        "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk"
      }
    },
    {
      "type": "node-terminal",
      "name": "Minecraft Client (:forge)",
      "request": "launch",
      "command": "./gradlew :forge:runClient",
      "cwd": "${workspaceFolder}",
      "env": {
        "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk"
      }
    }
  ]
}
