{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Mods",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        "build",
        "copyReleaseJars"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": "build",
      "presentation": {
        "group": "Mod Development",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Minecraft Client (:neoforge)",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":neoforge:runClient"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": "build",
      "presentation": {
        "group": "Mod Development",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Minecraft Client (:fabric)",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":fabric:runClient"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": "build",
      "presentation": {
        "group": "Mod Development",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Build NeoForge",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":neoforge:build"
      ],
      "options": {
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": "build"
    },
    {
      "label": "Build Fabric",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":fabric:build"
      ],
      "options": {
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": "build"
    },
    {
      "label": "Fix VS Code Classpath",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":common:eclipse",
        ":fabric:eclipse",
        ":neoforge:eclipse"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": "build",
      "detail": "Regenerates .classpath files so VS Code picks up the current Minecraft version. Then run 'Java: Clean Java Language Server Workspace' and reload.",
      "presentation": {
        "group": "Mod Development",
        "panel": "dedicated",
        "reveal": "always",
        "focus": true
      },
      "problemMatcher": [
        "$gradle"
      ]
    },
    {
      "label": "Refresh IDE After Version Update",
      "command": "bash",
      "type": "shell",
      "args": [
        "-c",
        "./gradlew --refresh-dependencies help --quiet && ./gradlew --no-parallel refreshIde"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": "build",
      "detail": "Run after changing minecraft_version in gradle.properties. Refreshes deps, regenerates Minecraft sources, recompiles, and updates IDE classpath files. Then run 'Java: Clean Java Language Server Workspace' and reload.",
      "presentation": {
        "group": "Mod Development",
        "panel": "dedicated",
        "reveal": "always",
        "focus": true
      },
      "problemMatcher": [
        "$gradle"
      ]
    }
  ]
}
