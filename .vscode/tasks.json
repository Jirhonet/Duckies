{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Mods",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        "build",
        "copyReleaseJars"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "group": "Mod Development",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Minecraft Client (:forge)",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":forge:runClient"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "group": "Mod Development",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Prepare Fabric Client",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":common:classes",
        ":fabric:classes",
        ":fabric:configureClientLaunch"
      ],
      "options": {
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk"
        }
      },
      "group": "build"
    },
    {
      "label": "Build Forge",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":forge:build"
      ],
      "options": {
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk"
        }
      },
      "group": "build"
    },
    {
      "label": "Build Fabric",
      "command": "./gradlew",
      "type": "shell",
      "args": [
        ":fabric:build"
      ],
      "options": {
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk"
        }
      },
      "group": "build"
    }
  ]
}
